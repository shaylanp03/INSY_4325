# ── Load data ──────────────────────────────────────────────────────────────────
@st.cache_data
def load_data():
    try:
        df = pd.read_csv("house_data.csv")
    except FileNotFoundError:
        # fallback: try uploaded path
        df = pd.read_csv("/mnt/user-data/uploads/house_data.csv")
    df["price"] = pd.to_numeric(df["price"], errors="coerce")
    df = df.dropna(subset=["price"])
    df["zipcode"] = df["zipcode"].astype(int)
    return df

df = load_data()

# ── Pre-compute dataset context for the AI ─────────────────────────────────────
@st.cache_data
def build_context(df):
    zip_stats = (
        df.groupby("zipcode")["price"]
        .agg(avg_price="mean", count="count")
        .reset_index()
        .sort_values("avg_price")
    )
    budget_buckets = {
        "under_300k":  int((df["price"] <  300000).sum()),
        "300k_500k":   int(((df["price"] >= 300000) & (df["price"] < 500000)).sum()),
        "500k_800k":   int(((df["price"] >= 500000) & (df["price"] < 800000)).sum()),
        "800k_1m":     int(((df["price"] >= 800000) & (df["price"] < 1000000)).sum()),
        "over_1m":     int((df["price"] >= 1000000).sum()),
    }
    return {
        "total_listings": len(df),
        "price_min": int(df["price"].min()),
        "price_max": int(df["price"].max()),
        "price_avg": int(df["price"].mean()),
        "price_median": int(df["price"].median()),
        "zipcodes": sorted(df["zipcode"].unique().tolist()),
        "bedrooms_available": sorted(df["bedrooms"].unique().tolist()),
        "budget_buckets": budget_buckets,
        "top_luxury_zips": zip_stats.nlargest(5, "avg_price")[["zipcode","avg_price","count"]].to_dict("records"),
        "top_affordable_zips": zip_stats.nsmallest(5, "avg_price")[["zipcode","avg_price","count"]].to_dict("records"),
        "waterfront_count": int((df["waterfront"] == 1).sum()),
        "has_basement_count": int((df["sqft_basement"] > 0).sum()),
    }

data_context = build_context(df)

