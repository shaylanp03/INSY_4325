# ── Search function ────────────────────────────────────────────────────────────
def search_homes(df, params):
    mask = (
        (df["price"]     >= params.get("min_price", 0)) &
        (df["price"]     <= params.get("max_price", 9999999)) &
        (df["bedrooms"]  >= params.get("min_beds", 0)) &
        (df["bedrooms"]  <= params.get("max_beds", 20)) &
        (df["bathrooms"] >= params.get("min_baths", 0)) &
        (df["bathrooms"] <= params.get("max_baths", 20)) &
        (df["grade"]     >= params.get("min_grade", 1)) &
        (df["grade"]     <= params.get("max_grade", 13)) &
        (df["condition"] >= params.get("min_condition", 1)) &
        (df["view"]      >= params.get("min_view", 0)) &
        (df["sqft_living"] >= params.get("min_sqft", 0)) &
        (df["sqft_living"] <= params.get("max_sqft", 99999))
    )
    if params.get("waterfront") is True:
        mask &= (df["waterfront"] == 1)
    if params.get("has_basement") is True:
        mask &= (df["sqft_basement"] > 0)
    if params.get("zipcodes"):
        mask &= df["zipcode"].isin(params["zipcodes"])
    return df[mask].sort_values("price").reset_index(drop=True)

def extract_search_params(text):
    """Extract JSON search block from assistant response."""
    match = re.search(r'```json\s*(\{.*?\})\s*```', text, re.DOTALL)
    if match:
        try:
            params = json.loads(match.group(1))
            if params.get("search"):
                return params
        except Exception:
            pass
    return None

def clean_response(text):
    """Remove the JSON block from display text."""
    return re.sub(r'```json\s*\{.*?\}\s*```', '', text, flags=re.DOTALL).strip()

